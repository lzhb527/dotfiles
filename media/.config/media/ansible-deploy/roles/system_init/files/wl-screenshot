#!/bin/sh

# 1. 配置图片保存路径（默认保存在用户家目录的“图片/Screenshots”文件夹下）
SAVE_DIR="$HOME/Pictures/Screenshots"
mkdir -p "$SAVE_DIR"

# 生成带时间戳的唯一文件名
FILENAME="Screenshot_$(date +'%Y%m%d_%H%M%S').png"
FILE_PATH="$SAVE_DIR/$FILENAME"

# 2. 判断截图模式
case "$1" in
    area)
        # 区域截图：通过 slurp 获取坐标，grim 截图
        # 用 slurp -b 和 -c 可以美化选择框的边框和背景颜色
        GEOMETRY=$(slurp -b "#00000044" -c "#08adbaff" -w 2)

        # 如果用户中途按 Esc 取消了拉框，则直接退出脚本
        [ -z "$GEOMETRY" ] && exit 0

        grim -g "$GEOMETRY" "$FILE_PATH"
        ;;
    full)
        # 全屏截图
        grim "$FILE_PATH"
        ;;
    *)
        echo "使用方法: $0 {area|full}"
        exit 1
        ;;
esac

# 3. 如果截图成功，执行后续联动
if [ -f "$FILE_PATH" ]; then
    # 【核心动作 A】将截图无损送入系统剪贴板，方便 Ctrl+V 粘贴
    wl-copy < "$FILE_PATH"

    # 【核心动作 B】唤起轻量级编辑工具 Swappy（可选，不需要可删掉这行）
    # 它会弹出一个小工具条，允许你画箭头、马赛克、写文字，按保存会自动覆盖原图
    swappy -f "$FILE_PATH" -o "$FILE_PATH"

    # 【核心动作 C】发送漂亮的桌面通知（支持点击通知直接打开文件夹）
    notify-send "📷 截图成功" "已保存并复制到剪贴板\n文件名: $FILENAME" -i image-x-generic
fi

