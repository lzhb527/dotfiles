/* 定义颜色变量 */
@define-color module_bg rgba(255, 255, 255, 0.1);
@define-color hover_bg #08bdba;

* {
    font-family: "JetBrainsMono Nerd Font", "Font Awesome 6 Free", sans-serif;
    font-size: 14px;
    border: none;
    border-radius: 0;
}

window#waybar {
    background-color: rgba(22,22,22,0.5);
    border-bottom: 2px solid rgba(100, 114, 125, 0.3);
    color: #ffffff;
    transition: background-color 0.5s;
    border-radius: 8px;
}

/* 通用模块样式 */
#clock, #battery, #cpu, #memory, #tray, #network, #power-profiles-daemon, #pulseaudio, #mpd, #custom-showdesktop, #custom-notification {
    padding: 0 10px;
    margin: 4px 2px;
    border-radius: 4px;
    background-color: @module_bg;
}
#clock:hover {
    background-color: #f9e2af;
    color: #1e1e2e;
}
