/* 电池低电量报警 */
#battery.critical:not(.charging) {
    background-color: #f53c3c;
    color: #ffffff;
    animation: blink 0.5s linear infinite alternate;
}

@keyframes blink {
    to {
        background-color: #ffffff;
        color: #000000;
    }
}

/* 启动器样式 */
#custom-launcher {
    background-color: rgba(137, 180, 250, 0.2);
    color: #08bdba;
    font-size: 18px;
    padding: 0 12px;
    margin: 4px 5px 4px 10px;
    border-radius: 8px;
    transition: all 0.3s ease;
}

#custom-launcher:hover {
    background-color: #08bdba;
    color: #1e1e2e;
}

/* 注销按钮样式 */
#custom-logout {
    background-color: @module_bg;
    color: #ffffff;
    border-radius: 4px;
    padding: 0 10px;
    margin: 4px 2px;
    font-weight: bold;
}

#custom-logout:hover {
    background-color: #f9e2af;
    color: #1e1e2e;
}

/* --- Taskbar 任务栏 --- */
#taskbar {
    background-color: @module_bg;
    margin: 4px;
    padding: 0 8px;
    border-radius: 8px;
}

#taskbar button {
    padding: 0 8px;
    border-bottom: 3px solid transparent;
    transition: all 0.3s ease;
}

#taskbar button.active {
    background-color: rgba(8, 189, 186, 0.25);
    border-bottom: 3px solid @hover_bg;
}

#taskbar button:hover {
    background-color: rgba(8, 189, 186, 0.15);
    border-bottom: 3px solid rgba(8, 189, 186, 0.65);
}

