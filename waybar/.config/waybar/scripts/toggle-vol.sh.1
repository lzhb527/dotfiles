# 查找真正的进程 PID（排除正在执行 grep 的自身进程）
PID=$(ps aux | grep 'vol.sh' | grep -v 'grep' | awk '{print $2}')

if [ -n "$PID" ]; then
    # 如果进程存在，则关闭它
    kill $PID
else
    # 如果进程不存在，则在后台启动它
    bash /home/lee/.config/waybar/scripts/vol.sh &
fi
